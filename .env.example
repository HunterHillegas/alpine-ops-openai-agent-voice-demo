# Server-only OpenAI API key. Leave blank for mock voice mode.
OPENAI_API_KEY=

# API CORS origin for deployed/local web clients.
ALLOWED_ORIGIN=http://localhost:5173

# Browser-facing API origin for Vite builds and local web smoke runs.
VITE_API_URL=http://localhost:8787

# Set only after npm run test:live and the manual microphone checklist pass.
LIVE_VOICE_VERIFIED=
